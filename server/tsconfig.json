{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "types": ["node"],
    "incremental": true,
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "declaration": false,
    "declarationMap": false,
    "tsBuildInfoFile": "dist/.tsbuildinfo"
  },
  "include": ["src"],
  "exclude": [
    "node_modules",
    "../node_modules",
    "**/node_modules/**",
    "dist",
    "coverage",
    "playwright-report"
  ],
  "references": [{ "path": "../shared" }]
}
