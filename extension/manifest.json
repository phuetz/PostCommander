{
  "manifest_version": 3,
  "name": "PostCommander",
  "version": "1.0.0",
  "description": "AI-powered social media management from your browser.",
  "action": {
    "default_popup": "src/popup/index.html"
  },
  "background": {
    "service_worker": "src/background/service-worker.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["*://*.linkedin.com/*"],
      "js": ["src/content/linkedin.tsx"]
    }
  ],
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "http://localhost:3001/*",
    "*://*.linkedin.com/*"
  ]
}
