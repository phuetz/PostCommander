# Server
PORT=3001
NODE_ENV=development
JWT_SECRET=replace-with-a-long-random-secret
ENCRYPTION_KEY=your-32-byte-hex-key-here
ADMIN_EMAILS=admin@example.com
PASSWORD_RESET_WEBHOOK_URL=
BASE_URL=http://localhost:3001
CLIENT_URL=http://localhost:5173
REDIS_URL=redis://localhost:6379
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postcommander

# LLM Providers (at least one required)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
MISTRAL_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# OSINT & Agentic Growth Engine (Required for advanced features)
TAVILY_API_KEY=
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=
LINKEDIN_SESSION_COOKIE= # li_at cookie

# Mem0 Vector Memory
# Option A: Use Mem0 Cloud API (Easiest for MVP)
MEM0_API_KEY=
# Option B: Use Local Docker Mem0 (Self-hosted)
# 1. Run `docker compose -f docker-compose.mem0.yml up -d`
# 2. Uncomment the line below and leave MEM0_API_KEY blank
# MEM0_HOST=http://localhost:8000

